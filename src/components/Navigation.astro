---
import ThemeInput from "@components/ThemeInput.astro";
import Image from "@components/Image.astro";
import { owner } from "@data/constants";
---

<header
  class="to-base-100 sticky top-0 z-10 w-full bg-linear-to-t from-transparent backdrop-blur-sm"
>
  <div class="mx-auto flex h-16 max-w-6xl px-5">
    <div class="flex-1">
      <a
        title="Home page"
        class="btn btn-ghost btn-lg h-full gap-3 py-4 max-sm:px-1"
        href="/"
      >
        <Image {...owner.pfp} inferSize class="size-8.75 rounded-xl" />
        {owner.name}
      </a>
    </div>
    <div class="flex flex-1 items-center justify-end">
      <ThemeInput class="btn btn-ghost aspect-square h-full" />
    </div>
  </div>
</header>
