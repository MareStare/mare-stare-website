---
import BaseImage from "@components/Image.astro";

interface Props {
  src: string;
  alt: string;
  class?: string;
  noMaxWidth?: boolean;
}

const { noMaxWidth, ...props } = Astro.props;
---

<BaseImage
  {...props}
  class:list={[
    "rounded-box",
    "border-base-300",
    "w-full",
    !noMaxWidth &&
      !props.class?.includes("max-w-") &&
      "max-w-[calc(min(var(--spacing)*100,100%))]",
    "border",
    "shadow-md",
  ]}
  inferSize
/>
